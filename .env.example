# API propia
APP_NAME=pui-webhook
DEBUG=false
JWT_SECRET_KEY=cambiar-por-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Credenciales que la PUI usará para llamar a ESTE servicio (manual 8.1: usuario fijo PUI)
PUI_WEBHOOK_PASSWORD=CambiarClave16a20chars!

# Cliente hacia la Plataforma Única de Identidad (consumo de endpoints sección 7)
PUI_BASE_URL=https://pui.example.mx
PUI_INSTITUCION_ID=XXXXXXXXXXXXX
PUI_CLAVE=clave_otorgada_por_area_tecnica
# Opcional (simulador): JWT hacia la PUI sin POST /login. Dejar vacío para usar login con PUI_CLAVE.
PUI_BEARER_TOKEN=
# Si true, POST /activar-reporte-prueba llama a la PUI /login (conectividad). Por defecto false.
PUI_PRUEBA_VERIFICAR_LOGIN_REMOTO=false

# Oracle
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_USER=PUI
ORACLE_PASSWORD=cambiar
ORACLE_SERVICE_NAME=ORCL
ORACLE_SCHEMA=ESIACOM
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5
# Si true, no conecta a Oracle y usa datos simulados
ORACLE_SIMULATE=false

# Búsqueda continua (fase 3): intervalo en segundos
CONTINUOUS_SEARCH_INTERVAL_SECONDS=3600
